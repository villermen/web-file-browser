{
    "name": "villermen/web-file-browser",
    "description": "Configurable web file browser for listing files, directories and webpages.",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "symfony/http-foundation": "^7.3",
        "symfony/yaml": "^7.3",
        "twig/twig": "^3.3",
        "villermen/data-handling": "^1.15"
    },
    "config": {
        "platform": {
            "php": "8.2"
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Villermen",
            "email": "villermen@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": { "": "src/" }
    },
    "require-dev": {
        "symfony/var-dumper": "^7.3"
    },
    "scripts": {
        "dev-server": [
            "Composer\\Config::disableProcessTimeout",
            "php -S localhost:8080 -t public public/index.php"
        ],
        "post-install-cmd": "Villermen\\WebFileBrowser\\ComposerScripts::postInstall"
    }
}
