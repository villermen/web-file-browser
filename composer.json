{
    "name": "villermen/web-file-browser",
    "description": "Configurable web file browser for listing files, directories and webpages.",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "ext-zip": "*",
        "symfony/http-foundation": "^7.4.13",
        "symfony/yaml": "^7.4.13",
        "twig/twig": "^3.27.1",
        "villermen/data-handling": "^2.1.0"
    },
    "config": {
        "platform": {
            "php": "8.3.6"
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Villermen",
            "email": "villermen@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": { "Villermen\\WebFileBrowser\\": "src/" }
    },
    "require-dev": {
        "symfony/var-dumper": "^7.4.8"
    },
    "scripts": {
        "dev-server": [
            "Composer\\Config::disableProcessTimeout",
            "php -S localhost:8080 -t public public/index.php"
        ]
    }
}
